{
  "manifest_version": 3,
  "name": "Advanced Media Player",
  "version": "1.0.0",
  "description": "Advanced media player with DSP processing, equalizer, and media controls.",

  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["pkg/*", "worker.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_icon": "icons/icon.svg",
    "default_title": "Advanced Media Controller",
    "default_popup": "popup.html"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
